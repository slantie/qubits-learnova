# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://learnova_video:learnova_video_pass@localhost:5433/learnova_video

# ─── Service Auth (shared secret between monolith and video service) ─────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SERVICE_AUTH_SECRET=CHANGE_ME_generate_with_command_above

# ─── Service Base URL (used for proxy stream URLs in responses) ──────────────
# SERVICE_BASE_URL=https://video.yourdomain.com

# ─── Storage Provider ────────────────────────────────────────────────────────
# Toggle between "local" (MinIO) and "s3" (AWS S3)
STORAGE_PROVIDER=local

# Bucket names — shared across both providers
STORAGE_BUCKET_RAW=video-raw
STORAGE_BUCKET_PROCESSED=video-processed

# ─── Local Storage (MinIO) — used when STORAGE_PROVIDER=local ───────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# ─── AWS S3 — used when STORAGE_PROVIDER=s3 ─────────────────────────────────
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# CDN_URL=https://cdn.yourdomain.com   # (optional) CloudFront / CDN base URL

# ─── Redis (BullMQ job queue) ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Transcoding ──────────────────────────────────────────────────────────────
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
MAX_CONCURRENT_JOBS=2
TRANSCODE_RESOLUTIONS=360,480,720,1080

# ─── Webhook (monolith callback) ──────────────────────────────────────────────
DEFAULT_CALLBACK_URL=http://localhost:4000/api/webhooks/video
