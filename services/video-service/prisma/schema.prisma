generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VideoStatus {
  UPLOADING
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum StorageProvider {
  local
  s3
}

model Video {
  id              String          @id @default(uuid())
  originalName    String
  mimeType        String
  fileSize        BigInt
  status          VideoStatus     @default(UPLOADING)
  storageProvider StorageProvider  @default(local)

  duration Float?

  rawKey       String  @unique
  thumbnailKey String?
  hlsKey       String?

  resolutions Json?

  errorMessage String?

  callbackUrl String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime?

  @@index([status])
  @@index([storageProvider])
  @@map("videos")
}
